{
  "name": "qiuye-electron-template",
  "productName": "QiuYe Electron Template",
  "version": "0.1.0",
  "description": "A personal Electron application template for QiuYeDx projects.",
  "author": "QiuYeDx <qiuyedx@foxmail.com>",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "dist-electron/main/index.js",
  "packageManager": "pnpm@8.7.0",
  "engines": {
    "node": ">=18.18.0 <23",
    "pnpm": "8.7.0"
  },
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:7777/"
    }
  },
  "template": {
    "update": {
      "owner": "QiuYeDx",
      "repo": "qiuye-electron-template",
      "releasesUrl": "https://github.com/QiuYeDx/qiuye-electron-template/releases",
      "changelogUrl": "https://raw.githubusercontent.com/QiuYeDx/qiuye-electron-template/main/CHANGELOG.md"
    }
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 7777",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:renderer": "corepack pnpm typecheck && vite build",
    "build": "corepack pnpm build:renderer && electron-builder --publish never",
    "release:dir": "corepack pnpm build:renderer && electron-builder --dir --publish never",
    "release:current": "corepack pnpm build",
    "release:mac": "corepack pnpm build:renderer && electron-builder --mac --publish never",
    "release:win": "corepack pnpm build:renderer && electron-builder --win --publish never",
    "i18n:check": "node scripts/check-i18n.mjs",
    "check": "corepack pnpm typecheck && corepack pnpm i18n:check"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.3",
    "@reactuses/core": "^6.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.11",
    "i18next": "^24.2.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-i18next": "^15.4.0",
    "react-router-dom": "^7.1.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@types/node": "^22.10.2",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.2.0",
    "electron-builder": "^24.13.3",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5.4.2",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "pnpm": {
    "overrides": {
      "builder-util-runtime": "^9.3.1"
    }
  }
}
